        "selector": {
          "type": "SvgSelector",
          "value": "<svg><polygon points=\"3741.4736842105262,6270 875.6842105263154,6258.421052631579 945.1578947368416,5256.842105263159 3428.8421052631584,5320.526315789475 3382.5263157894738,5557.894736842107 2954.1052631578946,5592.631578947368 2988.842105263158,6084.736842105264 3718.315789473684,6102.105263157895\" /></svg>"
        }
