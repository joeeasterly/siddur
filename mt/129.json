    {
      "id": "2e98c00c-6f45-4281-a456-857006365766",
      "target": {
        "source": "mishkan:page:1d22ad1b-bafa-48a8-bf42-71ae4eb2c142",
        "type": "SpecificResource",
        "selector": {
          "type": "SvgSelector",
          "value": "<svg><polygon points=\"3017.789473684211,712.1052631578943 3029.3684210526317,509.4736842105258 916.210526315789,665.7894736842104 898.8421052631574,2420 4604.105263157895,2501.0526315789475 4343.578947368421,1719.4736842105262 2635.684210526316,1678.9473684210525 2664.6315789473683,729.473684210526\" /></svg>"
