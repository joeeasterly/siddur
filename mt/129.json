        {
          "type": "TextualBody",
          "purpose": "transcribing",
          "value": "כִּי אֶשְׁמְרָה שַׁבָּת אֵל יִשְׁמְרֵנִי.\nאוֹת הִיא לְעוֹלְמֵי עַד בֵּינוֹ וּבֵינִי.",
          "language": "he"
        }
