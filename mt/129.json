      "@context": "http://www.w3.org/ns/anno.jsonld",
      "type": "Annotation",
      "body": [
        {
          "type": "TextualBody",
          "purpose": "transcribing",
          "value": "Kol dodi hinei zeh ba,\nmidaleig al heharim,\nKOL DODI\nm'kapeitz al hag'vaot.\nHark! My beloved comes leaping over the mountains, bounding over the hills.\n(Song of Songs 2:8)",
          "language": "en"
        }
      ],
      "created": "2026-07-14T17:42:38.729Z",
      "creator": {
