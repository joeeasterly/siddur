      "@context": "http://www.w3.org/ns/anno.jsonld",
      "type": "Annotation",
      "body": [
        {
          "type": "TextualBody",
          "purpose": "transcribing",
          "value": "Eileh chamdah libi,\nchusah na v'al na titalam.\nEILEH CHAMDAH LIBI\nGod is my heart's desire. Appear! Do not hide.",
          "language": "en"
        }
      ],
