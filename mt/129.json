        "selector": {
          "type": "SvgSelector",
          "value": "<svg><polygon points=\"3440.421052631579,4353.684210526316 3382.5263157894738,4180.000000000001 881.4736842105258,4261.052631578948 921.9999999999994,5181.578947368422 4627.263157894738,5175.782026674243 4523.0526315789475,4955.789473684211 2745.684210526316,4909.473684210527 2763.0526315789475,4411.578947368422\" /></svg>"
        }
