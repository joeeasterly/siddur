      "@context": "http://www.w3.org/ns/anno.jsonld",
      "type": "Annotation",
      "body": [
        {
          "type": "TextualBody",
          "purpose": "transcribing",
          "value": "KI ESHM'RAH SHABBAT\nKi eshm'rah Shabbat El yishm'reini.\nOt hi l'olmei ad beino uveini.\nWhen I keep Shabbat, God watches over me. It is a sign forever between God and me.",
          "language": "en"
        }
      ],
      "created": "2026-07-14T17:42:54.369Z",
