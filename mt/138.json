      "body": [
        {
          "type": "TextualBody",
          "purpose": "transcribing",
          "value": "שָׁמוֹר וְזָכוֹר בְּדִבּוּר אֶחָד,\nהִשְׁמִיעָנוּ אֵל הַמְיָחָד,\nיְיָ אֶחָד וּשְׁמוֹ אֶחָד\nT\nלְשֵׁם וּלְתִפְאֶרֶת וְלִתְהִלָּה.",
          "language": "he"
        }
      ],
      "created": "2026-07-14T17:50:13.322Z",
      "creator": {
        "isGuest": true,
        "id": "70rk_6FTJmtCxoqUq3TB"
