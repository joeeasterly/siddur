      "type": "Annotation",
      "body": [
        {
          "type": "TextualBody",
          "purpose": "transcribing",
          "value": "לִקְרַאת שַׁבָּת לְכוּ וְנֵלְכָה,\nכִּי הִיא מְקוֹר הַבְּרָכָה,\nמֵרֹאשׁ מִקֶדֶם נְסוּכָה,\nסוֹף מַעֲשֶׂה בְּמַחֲשָׁבָה תְּחִלָּה.",
          "language": "he"
        }
      ],
      "created": "2026-07-14T17:50:44.538Z",
      "creator": {
        "isGuest": true,
        "id": "70rk_6FTJmtCxoqUq3TB"
      },
      "image_url": "https://momoiro.hallyu.io/mishkan/iiif/3/mishkan%2Fb3dfd142-9803-446b-bccc-5af467dfc7cd.jp2/2193,2327,1563,683/max/0/default.jpg"
