      "@context": "http://www.w3.org/ns/anno.jsonld",
      "type": "Annotation",
      "body": [
        {
          "type": "TextualBody",
          "purpose": "transcribing",
          "value": "Likrat Shabbat l'chu v'neilcha,\nki hi m'kor hab'rachah,\nmeirosh mikedem n'suchah,\nsof maaseh b'machashava t'chilah.",
          "language": "en"
        }
      ],
      "created": "2026-07-14T17:50:53.485Z",
      "creator": {
        "isGuest": true,
        "id": "70rk_6FTJmtCxoqUq3TB"
