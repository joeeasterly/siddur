      "target": {
        "source": "mishkan:page:b3dfd142-9803-446b-bccc-5af467dfc7cd",
        "type": "SpecificResource",
        "selector": {
          "type": "FragmentSelector",
          "conformsTo": "http://www.w3.org/TR/media-frags/",
          "value": "xywh=pixel:561.2631578947367,3328.947368421053,1181.0526315789477,636.8421052631584"
        }
      },
      "@context": "http://www.w3.org/ns/anno.jsonld",
      "type": "Annotation",
      "body": [
        {
          "type": "TextualBody",
          "purpose": "transcribing",
          "value": "Mikdash Melech, ir m'luchah,\nkumi tz'i mitoch hahafeichah,\nrav lach shevet b'emek habacha,\nv'hu yachamol alayich chemlah.",
          "language": "en"
        }
      ],
      "created": "2026-07-14T17:51:26.402Z",
      "creator": {
        "isGuest": true,
        "id": "70rk_6FTJmtCxoqUq3TB"
      },
      "image_url": "https://momoiro.hallyu.io/mishkan/iiif/3/mishkan%2Fb3dfd142-9803-446b-bccc-5af467dfc7cd.jp2/561,3328,1181,636/max/0/default.jpg"
    },
    {
      "id": "7d3b0956-a90d-4346-8e77-070bb6a88931",
      "target": {
        "source": "mishkan:page:b3dfd142-9803-446b-bccc-5af467dfc7cd",
        "type": "SpecificResource",
        "selector": {
          "type": "FragmentSelector",
          "conformsTo": "http://www.w3.org/TR/media-frags/",
          "value": "xywh=pixel:665.4736842105261,3977.368421052632,3108.947368421053,266.3157894736846"
        }
      },
      "@context": "http://www.w3.org/ns/anno.jsonld",
      "type": "Annotation",
      "body": [
        {
          "type": "TextualBody",
          "purpose": "transcribing",
          "value": "Royal shrine, city of kings, rise up and leave your ravaged state.\nYou have dwelt long enough in the valley of tears; now God will shower mercy on you.",
          "language": "en"
        }
      ],
      "created": "2026-07-14T17:51:34.212Z",
      "creator": {
        "isGuest": true,
        "id": "70rk_6FTJmtCxoqUq3TB"
      },
      "image_url": "https://momoiro.hallyu.io/mishkan/iiif/3/mishkan%2Fb3dfd142-9803-446b-bccc-5af467dfc7cd.jp2/665,3977,3108,266/max/0/default.jpg"
    },
    {
      "id": "b2447835-b65d-4c4f-a050-cc61dbfb91a3",
      "target": {
        "source": "mishkan:page:b3dfd142-9803-446b-bccc-5af467dfc7cd",
        "type": "SpecificResource",
        "selector": {
          "type": "FragmentSelector",
          "conformsTo": "http://www.w3.org/TR/media-frags/",
          "value": "xywh=pixel:2269.157894736842,4284.21052631579,1464.7368421052638,665.7894736842109"
        }
      },
      "@context": "http://www.w3.org/ns/anno.jsonld",
      "type": "Annotation",
      "body": [
        {
          "type": "TextualBody",
          "purpose": "transcribing",
          "value": "הִתְנַעֲרִי, מֵעָפָר קוּמִי,\nלִבְשִׁי בִּגְדֵי תִפְאַרְתֵּךְ, עַמִּי,\nעַל יַד בֶּן יִשַׁי בֵּית הַלַּחְמִי,\nקָרְבָה אֶל נַפְשִׁי גְאָלָהּ.\nT T",
          "language": "he"
        }
      ],
      "created": "2026-07-14T17:51:43.977Z",
      "creator": {
        "isGuest": true,
        "id": "70rk_6FTJmtCxoqUq3TB"
      },
      "image_url": "https://momoiro.hallyu.io/mishkan/iiif/3/mishkan%2Fb3dfd142-9803-446b-bccc-5af467dfc7cd.jp2/2269,4284,1464,665/max/0/default.jpg"
    },
    {
      "id": "330a380a-cba9-473e-82e3-f205ef31a636",
      "target": {
        "source": "mishkan:page:b3dfd142-9803-446b-bccc-5af467dfc7cd",
        "type": "SpecificResource",
        "selector": {
          "type": "FragmentSelector",
          "conformsTo": "http://www.w3.org/TR/media-frags/",
          "value": "xywh=pixel:567.0526315789473,4301.578947368422,1186.8421052631581,602.105263157895"
        }
      },
      "@context": "http://www.w3.org/ns/anno.jsonld",
      "type": "Annotation",
      "body": [
        {
          "type": "TextualBody",
          "purpose": "transcribing",
          "value": "Hitnaari, mei-afar kumi,\nlivshi bigdei tifarteich ami,\nal yad ben Yishai Beit haLachmi,\nkorvah el nafshi g'alah.",
          "language": "en"
        }
      ],
      "created": "2026-07-14T17:51:54.175Z",
      "creator": {
        "isGuest": true,
        "id": "70rk_6FTJmtCxoqUq3TB"
      },
      "image_url": "https://momoiro.hallyu.io/mishkan/iiif/3/mishkan%2Fb3dfd142-9803-446b-bccc-5af467dfc7cd.jp2/567,4301,1186,602/max/0/default.jpg"
    },
    {
      "id": "de6929b9-9e5e-4a17-afcc-f8297e5a198b",
      "target": {
        "source": "mishkan:page:b3dfd142-9803-446b-bccc-5af467dfc7cd",
        "type": "SpecificResource",
        "selector": {
          "type": "FragmentSelector",
          "conformsTo": "http://www.w3.org/TR/media-frags/",
          "value": "xywh=pixel:671.2631578947368,4932.631578947369,2894.7368421052633,312.6315789473683"
        }
      },
      "@context": "http://www.w3.org/ns/anno.jsonld",
      "type": "Annotation",
      "body": [
        {
          "type": "TextualBody",
          "purpose": "transcribing",
          "value": "Lift yourself up! Shake off the dust! Array yourself in beauty, O my people!\nAt hand is Bethlehem's David, Jesse's son, bringing deliverance into my life.",
          "language": "en"
        }
      ],
      "created": "2026-07-14T17:52:00.983Z",
      "creator": {
        "isGuest": true,
        "id": "70rk_6FTJmtCxoqUq3TB"
      },
