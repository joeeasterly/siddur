    },
    {
      "id": "45ecba96-8cca-40f8-aa64-985c7df49887",
      "target": {
        "source": "mishkan:page:b3dfd142-9803-446b-bccc-5af467dfc7cd",
        "type": "SpecificResource",
        "selector": {
          "type": "FragmentSelector",
          "conformsTo": "http://www.w3.org/TR/media-frags/",
          "value": "xywh=pixel:688.6315789473683,3004.7368421052633,2900.526315789474,220.00000000000045"
        }
      },
      "@context": "http://www.w3.org/ns/anno.jsonld",
      "type": "Annotation",
      "body": [
        {
          "type": "TextualBody",
          "purpose": "transcribing",
          "value": "Come with me to meet Shabbat, forever a fountain of blessing.\nStill it flows, as from the start: the last of days, for which the first was made.",
          "language": "en"
        }
      ],
      "created": "2026-07-14T17:51:05.185Z",
      "creator": {
        "isGuest": true,
        "id": "70rk_6FTJmtCxoqUq3TB"
      },
      "image_url": "https://momoiro.hallyu.io/mishkan/iiif/3/mishkan%2Fb3dfd142-9803-446b-bccc-5af467dfc7cd.jp2/688,3004,2900,220/max/0/default.jpg"
    },
    {
      "id": "d9061c34-9fe2-4471-8cdd-17089e2e58d4",
      "target": {
        "source": "mishkan:page:b3dfd142-9803-446b-bccc-5af467dfc7cd",
        "type": "SpecificResource",
        "selector": {
          "type": "FragmentSelector",
