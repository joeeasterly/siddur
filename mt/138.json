      "type": "Annotation",
      "body": [
        {
          "type": "TextualBody",
          "purpose": "transcribing",
          "value": "\"Keep\" and \"remember”: a single command the Only God caused us to hear;\nthe Eternal is One, God's Name is One; glory and praise are God's.",
          "language": "en"
        }
      ],
      "created": "2026-07-14T17:50:32.920Z",
      "creator": {
        "isGuest": true,
        "id": "70rk_6FTJmtCxoqUq3TB"
