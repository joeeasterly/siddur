      "@context": "http://www.w3.org/ns/anno.jsonld",
      "type": "Annotation",
      "body": [
        {
          "type": "TextualBody",
          "purpose": "transcribing",
          "value": "מִקְדָּשׁ מֶלֶךְ עִיר מְלוּכָה,\nקוּמִי צְאִי מִתּוֹךְ הַהֲפֵכָה,\nרַב לָךְ שֶׁבֶת בְּעֵמֶק הַבָּכָא,\nוְהוּא יַחֲמוֹל עָלַיִךְ חֶמְלָה.",
          "language": "he"
        }
      ],
      "created": "2026-07-14T17:51:16.594Z",
      "creator": {
        "isGuest": true,
        "id": "70rk_6FTJmtCxoqUq3TB"
      },
      "image_url": "https://momoiro.hallyu.io/mishkan/iiif/3/mishkan%2Fb3dfd142-9803-446b-bccc-5af467dfc7cd.jp2/2280,3288,1476,683/max/0/default.jpg"
    },
    {
