      "type": "Annotation",
      "body": [
        {
          "type": "TextualBody",
          "purpose": "transcribing",
          "value": "Shamor v'zachor b'dibur echad,\nhishmianu El ham'yuchad,\nAdonai echad ush'mo echad,\nI'shem ul'tiferet v'lit'hilah.",
          "language": "en"
        }
      ],
      "created": "2026-07-14T17:50:24.660Z",
      "creator": {
        "isGuest": true,
        "id": "70rk_6FTJmtCxoqUq3TB"
