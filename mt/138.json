      "@context": "http://www.w3.org/ns/anno.jsonld",
      "type": "Annotation",
      "body": [
        {
          "type": "TextualBody",
          "purpose": "transcribing",
          "value": "This poem was composed by Shlomo Halevi Alkabetz, 16th-century Safed kabbalist. The first\neight verses are arranged acrostically according to the author's name.",
          "language": "en"
        }
      ],
      "created": "2026-07-14T17:52:07.387Z",
