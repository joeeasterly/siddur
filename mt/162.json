      "@context": "http://www.w3.org/ns/anno.jsonld",
      "type": "Annotation",
      "body": [
        {
          "type": "TextualBody",
          "purpose": "transcribing",
          "value": "YISM'CHU v'malchut'cha\nshomrei Shabbat v'korei oneg.\nAm m'kad'shei shvi-i,\nkulam yisb'u v'yitangu mituvecha.\nV'hashvi-i ratzita bo v'kidashto,\nchemdat yamim oto karata,\nzeicher l'maaseh v'reishit.",
          "language": "en"
        }
      ],
      "created": "2026-07-14T19:58:28.803Z",
      "creator": {
        "isGuest": true,
        "id": "2KFgwi8CBztauZiH_mK5"
      },
      "image_url": "https://momoiro.hallyu.io/mishkan/iiif/3/mishkan%2F57c34d72-3504-4b86-8741-451a75eb46f9.jp2/412,3403,1273,1226/max/0/default.jpg"
    },
    {
      "id": "e609bc98-9667-45f1-b92b-5cf2337cf57c",
      "target": {
        "source": "mishkan:page:57c34d72-3504-4b86-8741-451a75eb46f9",
        "type": "SpecificResource",
        "selector": {
          "type": "FragmentSelector",
