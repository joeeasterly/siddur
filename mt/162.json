          "value": "xywh=pixel:459.31262939958634,4729.413043478261,3465.7225672877844,918.6252587991721"
        }
      },
      "@context": "http://www.w3.org/ns/anno.jsonld",
      "type": "Annotation",
      "body": [
        {
          "type": "TextualBody",
          "purpose": "transcribing",
          "value": "THOSE WHO KEEP SHABBAT by calling it a delight\nwill rejoice in Your realm.\nThe people that hallow Shabbat will delight in Your goodness.\nFor, being pleased with the Seventh Day, You hallowed it\nas the most precious of days, drawing our attention to the work of Creation.",
          "language": "en"
        }
      ],
