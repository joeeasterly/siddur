      "@context": "http://www.w3.org/ns/anno.jsonld",
      "type": "Annotation",
      "body": [
        {
          "type": "TextualBody",
          "purpose": "transcribing",
          "value": "V'SHAMRU V'NEI YISRAEL\net HaShabbat,\nlaasot et HaShabbat I'dorotam\nb'rit olam.\nBeini u'vein b’nei Yisrael\not hi l'olam,\nki sheishet yamim asah Adonai\net hashamayim v'et haaretz,\nu'vayom hashvi-i shavat vayinafash.",
          "language": "en"
        }
      ],
      "created": "2026-07-14T19:58:10.216Z",
      "creator": {
        "isGuest": true,
        "id": "2KFgwi8CBztauZiH_mK5"
      },
      "image_url": "https://momoiro.hallyu.io/mishkan/iiif/3/mishkan%2F57c34d72-3504-4b86-8741-451a75eb46f9.jp2/417,637,1550,1581/max/0/default.jpg"
    },
    {
      "id": "e7edfb3b-a77a-415f-8fb2-71ddb44741a6",
      "target": {
        "source": "mishkan:page:57c34d72-3504-4b86-8741-451a75eb46f9",
        "type": "SpecificResource",
        "selector": {
          "type": "FragmentSelector",
          "conformsTo": "http://www.w3.org/TR/media-frags/",
          "value": "xywh=pixel:814.2360248447203,2312.802277432712,2881.142857142858,809.0165631469977"
        }
      },
      "@context": "http://www.w3.org/ns/anno.jsonld",
      "type": "Annotation",
      "body": [
        {
          "type": "TextualBody",
          "purpose": "transcribing",
          "value": "THE PEOPLE OF ISRAEL shall keep Shabbat,\nobserving Shabbat throughout the ages as a covenant for all time.\nIt is a sign for all time between Me and the people of Israel.\nFor in six days Adonai made heaven and earth,\nand on the seventh day God ceased from work and was refreshed.",
          "language": "en"
        }
      ],
      "created": "2026-07-14T19:58:17.532Z",
      "creator": {
        "isGuest": true,
        "id": "2KFgwi8CBztauZiH_mK5"
      },
      "image_url": "https://momoiro.hallyu.io/mishkan/iiif/3/mishkan%2F57c34d72-3504-4b86-8741-451a75eb46f9.jp2/814,2312,2881,809/max/0/default.jpg"
    },
    {
