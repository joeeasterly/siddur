      "type": "Annotation",
      "body": [
        {
          "type": "TextualBody",
          "purpose": "transcribing",
          "value": "וְשָׁמְרוּ בְנֵי יִשְׂרָאֵל\nאֶת־הַשַּׁבָּת,\nלַעֲשׂוֹת אֶת־הַשַׁבָּת לְדֹרֹתָם\nבְּרִית עוֹלָם.\nבֵּינִי וּבֵין בְּנֵי יִשְׂרָאֵל\nאוֹת הִיא לְעלָם,\nTH\nכִּי־שֵׁשֶׁת יָמִים עָשָׂה יְיָ\nאֶת־הַשָּׁמַיִם וְאֶת־הָאָרֶץ,\nוּבַיּוֹם הַשְּׁבִיעִי שָׁבַת וַיִּנָּפַשׁ.",
          "language": "he"
        }
      ],
      "created": "2026-07-14T19:58:03.357Z",
      "creator": {
        "isGuest": true,
        "id": "2KFgwi8CBztauZiH_mK5"
