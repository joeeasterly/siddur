      "@context": "http://www.w3.org/ns/anno.jsonld",
      "type": "Annotation",
      "body": [
        {
          "type": "TextualBody",
          "purpose": "transcribing",
          "value": "ישְׂמָחוּ בְמַלְכוּתְךָ\nשׁוֹמְרֵי שַׁבָּת וְקְוֹרְאֵי עֹנֶג.\nעַם מְקַדְּשֵׁי שְׁבִיעִי,\nכֻּלָּם יִשְׂבְּעוּ וְיִתְעַנְגוּ מְטוּבָךְ.\nוְהַשְׁבִיעִי רָצִיתָ בּוֹ וְקִדַּשְׁתּוֹ,\nחֶמְדַת יָמִים אוֹתוֹ קָרָאתָ,\nזֵכֶר לְמַעֲשֵׂה בְרֵאשִׁית.",
          "language": "he"
        }
      ],
      "created": "2026-07-14T19:58:23.442Z",
      "creator": {
        "isGuest": true,
        "id": "2KFgwi8CBztauZiH_mK5"
      },
      "image_url": "https://momoiro.hallyu.io/mishkan/iiif/3/mishkan%2F57c34d72-3504-4b86-8741-451a75eb46f9.jp2/2510,3414,1581,1310/max/0/default.jpg"
