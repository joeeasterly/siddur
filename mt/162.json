      "body": [
        {
          "type": "TextualBody",
          "purpose": "transcribing",
          "value": "V'shamru v'nei Yisrael... The people of Israel shall keep... Exodus 31:16-17\nYism'chu contains twenty-four Hebrew words said to correspond to the twenty-four hours of Shabbat.",
          "language": "en"
        }
