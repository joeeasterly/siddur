        {
          "type": "TextualBody",
          "purpose": "transcribing",
          "value": "A VERY OLD SONG aroused me into life\nwhen it drove away my low spirits.\nwith its royal language.\nA song of a generation silenced\nfrom the days of old\naroused me into life."
        }
      ],
