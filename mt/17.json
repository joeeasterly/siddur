      "@context": "http://www.w3.org/ns/anno.jsonld",
      "type": "Annotation",
      "body": [
        {
          "type": "TextualBody",
          "purpose": "transcribing",
          "value": "STANDING on the parted shores of history,\nwe still believe what we were taught\nbefore ever we stood at Sinai:\nthat wherever we are, it is eternally Egypt\nthat there is a better place, a Promised Land;\nthat the winding way to that promise passes\nthrough the wilderness\nthat there is no way to get from here to there\nexcept by joining hands, marching\ntogether."
        }
      ],
