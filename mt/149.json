      "body": [
        {
          "type": "TextualBody",
          "purpose": "transcribing",
          "value": "PRAISE to You, Adonai our God,\nfrom whom the evening flows.\nYour wisdom sets the way on which time and season glide;\nYour breath guides the sail of the stars.\nCreator of the tide of time and light,\nYou guide the current of day into night.\nAs heaven spans to infinity,\nYou set its course for eternity.\nPraise to You, Adonai our God,\nfrom whom the evening flows.\nבָּרוּךְ אַתָּה, יְיָ, הַמַּעֲרִיב עֲרָבִים.\nBaruch atah, Adonai, hamaariv aravim.",
          "language": "en"
        }
      ],
      "created": "2026-07-14T19:51:24.198Z",
      "creator": {
        "isGuest": true,
        "id": "XKV9Hdls3N_BQumWyt7j"
      },
