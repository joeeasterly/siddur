        {
          "type": "TextualBody",
          "purpose": "transcribing",
          "value": "NATION shall not take up sword against nation; they shall never again know war.",
          "language": "en"
        }
      ],
      "created": "2026-07-17T16:50:06.738Z",
      "creator": {
        "isGuest": true,
        "id": "y5ms5GtRrXzbkvH2xLd_"
      },
      "image_url": "https://momoiro.hallyu.io/mishkan/iiif/3/mishkan%2F34d6bcb7-665d-4fd5-8e0a-43e9fe49d3e8.jp2/838,3593,3634,233/max/0/default.jpg"
    },
    {
      "id": "93027950-6314-4bb2-9207-b52a759751f7",
      "target": {
        "source": "mishkan:page:34d6bcb7-665d-4fd5-8e0a-43e9fe49d3e8",
        "type": "SpecificResource",
