          "value": "xywh=pixel:1446.098347757671,4102.281667977971,2149.803304484658,1059.3233674272224"
        }
      },
      "@context": "http://www.w3.org/ns/anno.jsonld",
      "type": "Annotation",
      "body": [
        {
          "type": "TextualBody",
          "purpose": "transcribing",
          "value": "DON'T STOP after beating the swords\ninto ploughshares, don't stop! Go on beating\nand make musical instruments out of them.\nWhoever wants to make war again\nwill have to turn them into ploughshares first.",
          "language": "en"
        }
      ],
      "created": "2026-07-17T16:50:12.257Z",
      "creator": {
        "isGuest": true,
        "id": "y5ms5GtRrXzbkvH2xLd_"
      },
      "image_url": "https://momoiro.hallyu.io/mishkan/iiif/3/mishkan%2F34d6bcb7-665d-4fd5-8e0a-43e9fe49d3e8.jp2/1446,4102,2149,1059/max/0/default.jpg"
    },
    {
