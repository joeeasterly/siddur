        {
          "type": "TextualBody",
          "purpose": "transcribing",
          "value": "WE ARE A PEOPLE in whom the past endures,\nin whom the present is inconceivable without moments gone by.\nThe Exodus lasted a moment, a moment enduring forever.\nWhat happened once upon a time happens all the time.",
          "language": "en"
        }
      ],
