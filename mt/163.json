      "body": [
        {
          "type": "TextualBody",
          "purpose": "transcribing",
          "value": "A THOUGHT has blown the market place away.\nThere is a song on the wind and joy in the trees.\nShabbat arrives in the world,\nscattering a song in the silence of the night:\nEternity utters a day.",
          "language": "en"
        }
      ],
