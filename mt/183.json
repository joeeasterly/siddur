      "@context": "http://www.w3.org/ns/anno.jsonld",
      "type": "Annotation",
      "body": [
        {
          "type": "TextualBody",
          "purpose": "transcribing",
          "value": "In this traditional prayer that summarizes the Amidah for Friday night, God appears uniquely as\nmon hab'rachot, literally, an “abode” (or “place\") of blessing. Over time, however,\nthis reading was lost through a scribal error, and does not appear in traditional prayer books. We\nrestore it here, so as to sense God as a place where we can enter and be at home, a spiritual\ndestination where we go to find the blessings we seek.",
          "language": "en"
        }
      ],
