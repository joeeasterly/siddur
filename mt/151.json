      "@context": "http://www.w3.org/ns/anno.jsonld",
      "type": "Annotation",
      "body": [
        {
          "type": "TextualBody",
          "purpose": "transcribing",
          "value": "Torah is what God has revealed to us, and what we discern of God: ideas and ideals, laws and\nmitzvot, our religious heritage. It unfolds our memories of Abraham and Sarah, of Moses and\nMiriam and the Prophets. It is legislation and explanation, allowing questions that challenge,\nanswers that inspire: all a quest for meaning. It is our way of life, a path for our souls, and the\ndesign for a better world. John Rayner",
          "language": "en"
        }
      ],
