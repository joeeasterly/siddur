      "@context": "http://www.w3.org/ns/anno.jsonld",
      "type": "Annotation",
      "body": [
        {
          "type": "TextualBody",
          "purpose": "transcribing",
          "value": "עשֶׂה שָׁלוֹם בִּמְרוֹמָיו,\nהוּא יַעֲשֶׂה שָׁלוֹם עָלֵינוּ\nוְעַל כָּל יִשְׂרָאֵל, וְעַל כָּל יוֹשְׁבֵי תֵבֵל,\nוְאִמְרוּ: אָמֵן.",
          "language": "he"
        }
      ],
      "created": "2026-07-17T16:51:34.481Z",
      "creator": {
        "isGuest": true,
        "id": "xBAJpZLQa5VJbha9l2qO"
