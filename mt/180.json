      "@context": "http://www.w3.org/ns/anno.jsonld",
      "type": "Annotation",
      "body": [
        {
          "type": "TextualBody",
          "purpose": "transcribing",
          "value": "אֱלֹהַי, נְצֹר לְשׁוֹנִי מֵרָע וּשְׂפָתַי\nמִדַּבֵּר מִרְמָה, וְלִמְקַלְלַי נַפְשִׁי\nתִדּוֹם, וְנַפְשִׁי בֶּעָפָר לַכֹּל תִּהְיֶה.\nפְּתַח לִבִּי בְּתוֹרָתֶךָ, וּבְמִצְוֹתֶיךָ\nתִּרְדוֹף נַפְשִׁי, וְכֹל הַחוֹשְׁבִים\nעָלַי רָעָה, מְהֵרָה הָפַר עֲצָתָם\nוְקַלְקֵל מַחֲשַׁבְתָּם. עֲשֵׂה לְמַעַן\nשְׁמֶךָ, עֲשֵׂה לְמַעַן יְמִינֶךָ, עֲשֵׂה\nלְמַעַן קְדֶשָׁתֶךָ, עֲשֵׂה לְמַעַן\nתּוֹרָתֶךָ. לְמַעַן יֵחָלְצוּן יְדִידֶיךָ,\nהוֹשִׁיעָה יְמִינְךָ וַעֲנֵנִי.",
          "language": "he"
        }
      ],
      "created": "2026-07-17T16:50:38.213Z",
      "creator": {
        "isGuest": true,
        "id": "xBAJpZLQa5VJbha9l2qO"
