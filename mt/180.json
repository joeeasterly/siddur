      "type": "Annotation",
      "body": [
        {
          "type": "TextualBody",
          "purpose": "transcribing",
          "value": "May the words of my mouth and the meditations of my heart\nbe acceptable to You, Adonai, my Rock and my Redeemer.",
          "language": "en"
        }
      ],
      "created": "2026-07-17T16:51:26.576Z",
