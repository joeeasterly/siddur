      "body": [
        {
          "type": "TextualBody",
          "purpose": "transcribing",
          "value": "BARUCH atah, Adonai\nEloheinu, Melech haolam,\nasher kid'shanu b'mitzvotav v'tzivanu\nal mitzvat k'riat sh'ma\nl'hamlicho b'leivav shaleim ul'yachdo\nb'leiv tov ul'ovdo b'nefesh chafeitzah."
        }
      ],
      "created": "2026-07-11T20:04:43.752Z",
