      "body": [
        {
          "type": "TextualBody",
          "purpose": "transcribing",
          "value": "PEACE BE TO YOU, O ministering angels, messengers of the Most High,\nMajesty of majesties, Holy One of Blessing.\nEnter in peace, O messengers of peace, angels of the Most High,\nMajesty of majesties, Holy One of Blessing.\nBless me with peace, O messengers of peace, angels of the Most High,\nMajesty of majesties, Holy One of Blessing.\nDepart in peace, O messengers of peace, angels of the Most High,\nMajesty of majesties, Holy One of Blessing.",
          "language": "en"
        }
      ],
