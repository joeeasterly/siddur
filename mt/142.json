      "body": [
        {
          "type": "TextualBody",
          "purpose": "transcribing",
          "value": "שׁלוֹם עֲלֵיכֶם, מַלְאֲכֵי הַשָּׁרַת,\nמַלְאֲכֵי עֶלְיוֹן,\nמִמֶּלֶךְ מַלְכֵי הַמְלָכִים,\nהַקָּדוֹשׁ בָּרוּךְ הוּא.\nבּוֹאֲכֶם לְשָׁלוֹם, מַלְאֲכֵי הַשָׁלוֹם,\nמַלְאֲכֵי עֶלְיוֹן,\nמִמֶּלֶךְ מַלְכֵי הַמְּלָכִים,\nהַקָּדוֹשׁ בָּרוּךְ הוּא.\nבָּרְכוּנִי לְשָׁלוֹם, מַלְאֲכֵי הַשָּׁלוֹם,\nמַלְאֲכֵי עֶלְיוֹן,\nמִמֶּלֶךְ מַלְכֵי הַמְּלָכִים,\nהַקָּדוֹשׁ בָּרוּךְ הוּא.\nצֵאתְכֶם לְשָׁלוֹם, מַלְאֲכֵי הַשָׁלוֹם,\nמַלְאֲכֵי עֶלְיוֹן,\nמִמֶּלֶךְ מַלְכֵי הַמְּלָכִים,\nהַקָּדוֹשׁ בָּרוּךְ הוּא.",
          "language": "he"
        }
      ],
