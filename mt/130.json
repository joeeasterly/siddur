      "@context": "http://www.w3.org/ns/anno.jsonld",
      "type": "Annotation",
      "body": [
        {
          "type": "TextualBody",
          "purpose": "transcribing",
          "value": "L'CHU n'ran'na l'Adonai,\nnariyah l'tzur yisheinu.\nN'kadmah fanav b'todah,\nbizmirot naria lo.\nKi El gadol Adonai,\nuMelech gadol al kol elohim.\nAsher b'yado mech'k'rei aretz,\nv'to-afot harim lo.\nAsher lo hayam v'hu asahu,\nv'yabeshet yadav yatzaru.\nBo-u nishtachaveh v'nichraah,\nnivr'cha lifnei Adonai oseinu.\nKi hu Eloheinu,\nvaanachnu am marito v'tzon yado.\nHayom im b'kolo tishma-u.",
          "language": "en"
        }
      ],
      "created": "2026-07-14T00:55:39.541Z",
      "creator": {
        "isGuest": true,
        "id": "DH05qYhx8eAFlsN94L2E"
      },
