          "value": "xywh=pixel:1240.5737407292954,4110.595642768851,2166.2942289864027,927.6788473423985"
        }
      },
      "@context": "http://www.w3.org/ns/anno.jsonld",
      "type": "Annotation",
      "body": [
        {
          "type": "TextualBody",
          "purpose": "transcribing",
          "value": "COME, LET US SING joyously to Adonai,\nraise a shout for our Rock and Deliverer;\nlet us come into God's presence with praise;\nlet us raise a shout for God in song!\nFor Adonai is a great God,\nthe great ruler of all divine beings.",
          "language": "en"
        }
      ],
      "created": "2026-07-14T00:56:08.609Z",
      "creator": {
