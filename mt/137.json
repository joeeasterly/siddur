      "@context": "http://www.w3.org/ns/anno.jsonld",
      "type": "Annotation",
      "body": [
        {
          "type": "TextualBody",
          "purpose": "transcribing",
          "value": "THE VOICE OF ADONAI kindles flames of fire;\nthe voice of Adonai convulses the wilderness;\nAdonai convulses the wilderness of Kadesh;\nthe voice of Adonai causes hinds to calve,\nand strips forests bare;\nwhile in God's temple all say \"Glory!\"\nAdonai sat enthroned at the Flood;\nAdonai sits enthroned, sovereign forever.\nMay Adonai grant strength to God's people;\nmay Adonai bestow on God's people wellbeing.",
          "language": "en"
        }
      ],
