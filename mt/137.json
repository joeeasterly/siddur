      "body": [
        {
          "type": "TextualBody",
          "purpose": "transcribing",
          "value": "Kol Adonai chotzeiv lahavot eish,\nkol Adonai yachil midbar,\nyachil Adonai midbar Kadeish.\nKol Adonai y'choleil ayalot\nvayechesof y'arot\nuv'heichalo kulo omeir kavod.\nAdonai lamabul yashav\nvayeishev Adonai Melech l'olam.\nAdonai oz l'amo yitein\nAdonai y'vareich et amo vashalom.",
          "language": "en"
        }
      ],
      "created": "2026-07-14T17:49:23.580Z",
