      "@context": "http://www.w3.org/ns/anno.jsonld",
      "type": "Annotation",
      "body": [
        {
          "type": "TextualBody",
          "purpose": "transcribing",
          "value": "R'TZEI, Adonai Eloheinu, b’amcha Yisrael,\nut'filatam b'ahavah t'kabeil,\nut'hi l'ratzon tamid\navodat Yisrael amecha.\nEl karov l'chol korav,\np'nei el avadecha v'choneinu,\nsh'foch ruchacha aleinu.",
          "language": "en"
        }
      ],
      "created": "2026-07-17T16:45:31.615Z",
      "creator": {
        "isGuest": true,
        "id": "smiixhXHohCK6SH66esj"
      },
      "image_url": "https://momoiro.hallyu.io/mishkan/iiif/3/mishkan%2F8c66befe-d02e-4efa-b14b-057325ded09e.jp2/423,347,1723,1246/max/0/default.jpg"
    },
    {
      "id": "57b4c4bc-f965-4814-bcff-219702bfb833",
      "target": {
        "source": "mishkan:page:8c66befe-d02e-4efa-b14b-057325ded09e",
        "type": "SpecificResource",
        "selector": {
          "type": "FragmentSelector",
          "conformsTo": "http://www.w3.org/TR/media-frags/",
          "value": "xywh=pixel:371.1966955153422,1609.7560975609756,2861.211644374508,763.3359559402049"
        }
      },
      "@context": "http://www.w3.org/ns/anno.jsonld",
      "type": "Annotation",
      "body": [
        {
          "type": "TextualBody",
          "purpose": "transcribing",
          "value": "FIND FAVOR, Adonai, our God, with Your people Israel\nand accept their prayer in love.\nMay the worship of Your people Israel always be acceptable.\nGod who is near to all who call, turn lovingly to Your servants.\nPour out Your spirit upon us.",
          "language": "en"
        }
      ],
      "created": "2026-07-17T16:45:37.705Z",
      "creator": {
        "isGuest": true,
        "id": "smiixhXHohCK6SH66esj"
      },
      "image_url": "https://momoiro.hallyu.io/mishkan/iiif/3/mishkan%2F8c66befe-d02e-4efa-b14b-057325ded09e.jp2/371,1609,2861,763/max/0/default.jpg"
    },
    {
      "id": "e4856542-6605-4637-8120-7d0ca80ad820",
      "target": {
        "source": "mishkan:page:8c66befe-d02e-4efa-b14b-057325ded09e",
        "type": "SpecificResource",
        "selector": {
          "type": "FragmentSelector",
          "conformsTo": "http://www.w3.org/TR/media-frags/",
          "value": "xywh=pixel:2360.024390243903,2596.3808025177027,1661.683713611329,1599.370574350905"
        }
      },
      "@context": "http://www.w3.org/ns/anno.jsonld",
      "type": "Annotation",
      "body": [
        {
          "type": "TextualBody",
          "purpose": "transcribing",
          "value": "אֱלֹהֵינוּ וֵאלֹהֵי אֲבוֹתֵינוּ וְאִמּוֹתֵינוּ,\nיַעֲלֶה וְיָבֹא וְיִזְכֵר זִכְרוֹנֵנוּ\nוְזִכְרוֹן כָּל עַמָּךְ בֵּית יִשְׂרָאֵל לְפָנֶיךָ,\nלְטוֹבָה, לְחֵן וּלְחֶסֶד וּלְרַחֲמִים,\nלְחַיִּים וּלְשָׁלוֹם, בְּיוֹם\nראשׁ הַחֹדֶשׁ הַזֶּה.\nחַג הַמַּצוֹת הַזֶּה.\nחַג הַסֵּכּוֹת הַזֶּה.\nזָכְרֵנוּ, יְיָ אֱלֹהֵינוּ, בּוֹ לְטוֹבָה. אָמֵן.\nוּפָקְדֵנוּ בוֹ לִבְרָכָה. אָמֵן.\nוְהוֹשִׁיעֵנוּ בוֹ לְחַיִּים. אָמֵן.",
          "language": "he"
        }
      ],
      "created": "2026-07-17T16:45:46.950Z",
      "creator": {
        "isGuest": true,
        "id": "smiixhXHohCK6SH66esj"
      },
