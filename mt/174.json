    },
    {
      "id": "e2780654-aa8a-4488-828b-606ba5158fba",
      "target": {
        "source": "mishkan:page:8c66befe-d02e-4efa-b14b-057325ded09e",
        "type": "SpecificResource",
        "selector": {
          "type": "SvgSelector",
          "value": "<svg><polygon points=\"3076.6254917387887,2450.9834775767113 3050.6616837136116,2632.7301337529507 2302.904012588513,2632.7301337529507 2261.36191974823,4159.40204563336 464.6664044059793,4185.365853658537 578.9071597167585,2435.405192761605\" /></svg>"
        }
      },
      "@context": "http://www.w3.org/ns/anno.jsonld",
      "type": "Annotation",
      "body": [
        {
          "type": "TextualBody",
          "purpose": "transcribing",
          "value": "ROSH CHODESH, PESACH, AND SUKKOT\nEloheinu v'Elohei avoteinu v'imoteinu,\nyaaleh v'yavo, v'yizacheir zichroneinu\nv'zichron kol amcha beit Yisrael l'fanecha,\nl'tovah, l'chein ul'chesed ul'rachamim,\nl'chayim ul'shalom, b'Yom\nRosh HaChodesh hazeh.\nChag HaMatzot hazeh.\nChag HaSukkot hazeh.\nZochreinu, Adonai Eloheinu, bo l'tovah. Amen.\nUfokdeinu vo liv'rachah. Amen.\nV'hoshi-einu vo l'chayim. Amen.",
          "language": "en"
        }
      ],
      "created": "2026-07-17T16:46:04.654Z",
      "creator": {
        "isGuest": true,
        "id": "smiixhXHohCK6SH66esj"
      },
      "image_url": "https://momoiro.hallyu.io/mishkan/iiif/3/mishkan%2F8c66befe-d02e-4efa-b14b-057325ded09e.jp2/464,2435,2612,1750/max/0/default.jpg"
    },
    {
      "id": "e54ea8b4-f080-438b-9c73-27e247aafab8",
      "target": {
        "source": "mishkan:page:8c66befe-d02e-4efa-b14b-057325ded09e",
        "type": "SpecificResource",
        "selector": {
          "type": "FragmentSelector",
          "conformsTo": "http://www.w3.org/TR/media-frags/",
          "value": "xywh=pixel:921.6294256490951,4226.90794649882,2710.6215578284814,784.1070023603461"
        }
      },
      "@context": "http://www.w3.org/ns/anno.jsonld",
      "type": "Annotation",
      "body": [
        {
          "type": "TextualBody",
          "purpose": "transcribing",
          "value": "Our God and God of our fathers and mothers, on this\n(first day of the new month) - (day of Pesach)-(day of Sukkot)\nbe mindful of us and all Your people Israel,\nfor good, for love, for compassion, life and\nRemember us for wellbeing. Amen.\npeace.\nVisit us with blessing. Amen. Help us to a fuller life. Amen.",
          "language": "en"
        }
      ],
      "created": "2026-07-17T16:46:16.605Z",
      "creator": {
        "isGuest": true,
        "id": "smiixhXHohCK6SH66esj"
      },
      "image_url": "https://momoiro.hallyu.io/mishkan/iiif/3/mishkan%2F8c66befe-d02e-4efa-b14b-057325ded09e.jp2/921,4226,2710,784/max/0/default.jpg"
    },
    {
