      "target": {
        "source": "mishkan:page:8c66befe-d02e-4efa-b14b-057325ded09e",
        "type": "SpecificResource",
        "selector": {
          "type": "FragmentSelector",
          "conformsTo": "http://www.w3.org/TR/media-frags/",
          "value": "xywh=pixel:2832.565696302124,5192.761605035405,1292.9976396538168,1111.2509834775774"
