      "@context": "http://www.w3.org/ns/anno.jsonld",
      "type": "Annotation",
      "body": [
        {
          "type": "TextualBody",
          "purpose": "transcribing",
          "value": "וְתֶחֱזֶינָה עֵינֵינוּ בְּשׁוּבְךְ\nלְצִיּוֹן בְּרַחֲמִים.\nבָּרוּךְ אַתָּה, יְיָ,\nהַמַּחֲזִיר שְׁכִינָתוֹ לְצִיּוֹן.",
          "language": "he"
        }
      ],
      "created": "2026-07-17T16:46:26.302Z",
      "creator": {
        "isGuest": true,
        "id": "smiixhXHohCK6SH66esj"
      },
      "image_url": "https://momoiro.hallyu.io/mishkan/iiif/3/mishkan%2F8c66befe-d02e-4efa-b14b-057325ded09e.jp2/2832,5192,1292,1111/max/0/default.jpg"
    },
    {
      "id": "589e8e36-9b71-4934-8ef7-449ee25685d5",
      "target": {
        "source": "mishkan:page:8c66befe-d02e-4efa-b14b-057325ded09e",
        "type": "SpecificResource",
        "selector": {
          "type": "FragmentSelector",
          "conformsTo": "http://www.w3.org/TR/media-frags/",
          "value": "xywh=pixel:324.4618410700237,5171.9905586152645,2497.7183320220297,1085.2871754523994"
        }
      },
      "@context": "http://www.w3.org/ns/anno.jsonld",
      "type": "Annotation",
      "body": [
        {
          "type": "TextualBody",
          "purpose": "transcribing",
          "value": "V'techezenah eineinu b'shuv'cha\nl'Tzion b'rachamim.\nLET OUR EYES BEHOLD Your loving return to Zion.\nBlessed are You, Adonai, whose Presence returns to Zion.\nBaruch atah, Adonai,\nhamachazir Shechinato l'Tzion.",
          "language": "en"
        }
      ],
