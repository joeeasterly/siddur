      "@context": "http://www.w3.org/ns/anno.jsonld",
      "type": "Annotation",
      "body": [
        {
          "type": "TextualBody",
          "purpose": "transcribing",
          "value": "רְצָה, יְיָ אֱלֹהֵינוּ, בְּעַמְךְ יִשְׂרָאֵל,\nוּתְפִלָּתָם בְּאַהֲבָה תְקַבֵּל,\nוּתְהִי לְרָצוֹן תָּמִיד\nעֲבוֹדַת יִשְׂרָאֵל עַמֶּךָ.\nאֵל קָרוֹב לְכָל קִרְאָיו,\nפְּנֵה אֶל עֲבָדֶיךָ וְחָנֵּנוּ,\nשְׁפוֹךְ רוּחֲךָ עָלֵינוּ.",
          "language": "he"
        }
      ],
      "created": "2026-07-17T16:45:15.115Z",
      "creator": {
        "isGuest": true,
        "id": "smiixhXHohCK6SH66esj"
      },
