      "@context": "http://www.w3.org/ns/anno.jsonld",
      "type": "Annotation",
      "body": [
        {
          "type": "TextualBody",
          "purpose": "transcribing",
          "value": "Help me perfect my ways of loving and caring.\nInspire me to make myself whole\nso that I may honor Your name and\ncreate a world of justice and peace.\nMartin Buber",
          "language": "en"
        }
