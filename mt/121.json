      "type": "Annotation",
      "body": [
        {
          "type": "TextualBody",
          "purpose": "transcribing",
          "value": "○ SOURCE of light and truth,\nCreator of the eternal law of goodness,\nhelp us to find knowledge by which to live.\nLead us to take the words we shall speak\ninto our hearts and our lives.\nBless all who enter this sanctuary in need,\nall who bring the offerings of their hearts.\nMay our worship lead us to acts of kindness, peace and love.",
          "language": "en"
        }
      ],
      "created": "2026-07-13T00:52:12.347Z",
