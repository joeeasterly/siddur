      "body": [
        {
          "type": "TextualBody",
          "purpose": "transcribing",
          "value": "AS THESE SHABBAT CANDLES give light\nto all who behold them,\nso may we, by our lives, give light to all who behold us.\nAs their brightness reminds us\nof the generations of Israel who have kindled light,\nso may we, in our own day, be among those who kindle light.",
          "language": "en"
        }
      ],
