      "body": [
        {
          "type": "TextualBody",
          "purpose": "transcribing",
          "value": "אהֲבַת עוֹלָם\nבֵּית יִשְׂרָאֵל עַמְךְ אָהָבְתָּ,\nתּוֹרָה וּמִצְוֹת,\nIT T\nחֲקִים וּמִשְׁפָּטִים, אוֹתָנוּ לִמַּדְתָּ.\nעַל כֵּן, יְיָ אֱלֹהֵינוּ,\nבְּשָׁכְבֵּנוּ וּבְקוּמֵנוּ\nנָשִׂים בְּחֵקֶיךָ,\nוְנִשְׂמַח בְּדִבְרֵי תוֹרָתְךָ\nוּבְמִצְוֹתֶיךָ לְעוֹלָם וָעֶד.\nכִּי הֵם חַיֵּינוּ וְאֹרֶךְ יָמֵינוּ\nוּבָהֶם נֶהְגֶה יוֹמָם וָלָיְלָה.\nוְאַהֲבָתְךָ\nT\nאַל תָּסִיר מִמֶּנּוּ לְעוֹלָמִים.\nבָּרוּךְ אַתָּה, יְיָ,\nאוֹהֵב עַמּוֹ יִשְׂרָאֵל.\nT",
          "language": "he"
        }
      ],
