      "@context": "http://www.w3.org/ns/anno.jsonld",
      "type": "Annotation",
      "body": [
        {
          "type": "TextualBody",
          "purpose": "transcribing",
          "value": "Y'DID NEFESH\nY'did nefesh, av harachaman,\nm'shoch avd'cha el r'tzonecha.\nYarutz avd'cha k'mo ayal,\nyishtachaveh el mul hadarecha.\n\nHeart's delight, Source of mercy, draw Your servant into Your arms:\nI leap like a deer to stand in awe before You.",
          "language": "en"
        }
      ],
      "created": "2026-07-14T17:39:41.147Z",
