      "type": "Annotation",
      "body": [
        {
          "type": "TextualBody",
          "purpose": "transcribing",
          "value": "יְדִיד נֶפֶשׁ, אָב הָרַחֲמָן,\nמְשׁוֹךְ עַבְדְּךָ אֶל רְצוֹנֶךָ.\nיָרוּץ עַבְדְּךָ כְּמוֹ אַיָּל,\nיִשְׁתַּחֲוֶה אֶל מוּל הֲדָרֶךְ.",
          "language": "he"
        }
      ],
      "created": "2026-07-14T17:39:21.227Z",
