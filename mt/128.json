    },
    {
      "id": "ee43ac88-a637-4c7c-98c8-8d9371ba14e6",
      "target": {
        "source": "mishkan:page:1dc5045a-17a7-4fd9-a4a1-edf1934927c7",
        "type": "SpecificResource",
        "selector": {
          "type": "FragmentSelector",
          "conformsTo": "http://www.w3.org/TR/media-frags/",
          "value": "xywh=pixel:2159.157894736842,4226.315789473685,1945.263157894737,1007.3684210526317"
        }
      },
      "@context": "http://www.w3.org/ns/anno.jsonld",
      "type": "Annotation",
      "body": [
        {
          "type": "TextualBody",
          "purpose": "transcribing",
          "value": "הַחַמָּה מֵרֹאשׁ הָאִילָנוֹת נִסְתַּלְקָה,\nבְּאוּ וְנֵצֵא לִקְרַאת שַׁבָּת הַמַּלְכָּה.\nהִנֵּה הִיא יוֹרֶדֶת, הַקְדוֹשָׁה הַבְּרוּכָה.\nוְעִמָּהּ מַלְאָכִים, צְבָא שָׁלוֹם וּמְנוּחָה.\nבְּאִי בְּאִי הַמַּלְכָּה, בְּאִי בְּאִי הַכַּלָּה.\nשָׁלוֹם עֲלֵיכֶם, מַלְאֲכֵי הַשָּׁלוֹם.",
          "language": "he"
        }
      ],
      "created": "2026-07-14T17:40:15.332Z",
      "creator": {
        "isGuest": true,
        "id": "_wyLx1uUwa8DMMXAtTli"
      },
      "image_url": "https://momoiro.hallyu.io/mishkan/iiif/3/mishkan%2F1dc5045a-17a7-4fd9-a4a1-edf1934927c7.jp2/2159,4226,1945,1007/max/0/default.jpg"
    },
    {
      "id": "6be4785e-380f-4bec-b551-97906e281835",
      "target": {
        "source": "mishkan:page:1dc5045a-17a7-4fd9-a4a1-edf1934927c7",
        "type": "SpecificResource",
        "selector": {
          "type": "SvgSelector",
          "value": "<svg><polygon points=\"2882.8421052631584,4133.684210526316 2900.2105263157896,3983.157894736843 439.6842105263156,4110.526315789474 474.42105263157873,6391.578947368423 3351.7894736842104,6293.157894736843 3311.2631578947367,5285.78947368421 2043.3684210526314,5285.78947368421 2066.526315789474,4162.631578947369\" /></svg>"
        }
      },
      "@context": "http://www.w3.org/ns/anno.jsonld",
      "type": "Annotation",
      "body": [
        {
          "type": "TextualBody",
          "purpose": "transcribing",
          "value": "SHABBAT HAMALKAH\n\nHachamah meirosh ha-ilanot nistalkah,\nbo-u v'neitzei likrat Shabbat hamalkah.\nHinei hi yoredet, hak'doshah hab'ruchah.\nV'imah malachim, tz'va shalom um'nuchah.\nBo-i bo-i hamalkah, bo-i bo-i hakalah.\nShalom aleichem, malachei hashalom.\n\nThe sun on the treetops no longer is seen;\ncome, gather to welcome the Sabbath, our queen.\nBehold her descending, the holy, the blessed,\nand with her the angels of peace and of rest.\nDraw near, draw near, and here abide,\ndraw near, draw near, O Sabbath bride.\nPeace also to you, you angels of peace.",
          "language": "en"
        }
      ],
