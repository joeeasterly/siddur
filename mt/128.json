          "value": "<svg><polygon points=\"2691.789473684211,2715.263157894737 2703.368421052632,2512.631578947369 428.1052631578946,2558.947368421053 428.1052631578946,3780.526315789474 3739.684210526316,3792.1052631578955 3733.894736842106,3502.631578947369 2714.9473684210525,3479.473684210527\" /></svg>"
