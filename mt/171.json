      "@context": "http://www.w3.org/ns/anno.jsonld",
      "type": "Annotation",
      "body": [
        {
          "type": "TextualBody",
          "purpose": "transcribing",
          "value": "WHERE might I go to find You,\nExalted, Hidden One?\nYet where would I not go to find You,\nEverpresent, Eternal One?\nMy heart cries out to You:\nPlease draw near to me.\nThe moment I reach out for You,\nI find You reaching in for me.",
          "language": "en"
        }
      ],
      "created": "2026-07-15T15:01:31.496Z",
