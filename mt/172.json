    },
    {
      "id": "f6bb4df5-1821-416f-8ee5-94fc1da87ac5",
      "target": {
        "source": "mishkan:page:189bce48-e52f-44ee-8d1f-2ea21ceaf4a5",
        "type": "SpecificResource",
        "selector": {
          "type": "FragmentSelector",
          "conformsTo": "http://www.w3.org/TR/media-frags/",
          "value": "xywh=pixel:433.89473684210526,3577.8947368421045,1771.578947368421,1511.052631578948"
        }
      },
      "@context": "http://www.w3.org/ns/anno.jsonld",
      "type": "Annotation",
      "body": [
        {
          "type": "TextualBody",
          "purpose": "transcribing",
          "value": "Eloheinu v'Elohei avoteinu v'imoteinu,\nr'tzeih vim'nuchateinu. Kad'sheinu b'mitzvotecha\nv'tein chelkeinu b'Toratecha.\nSabeinu mituvecha, v'samcheinu biy'shuatecha,\nv'taheir libeinu l'ovd'cha be-emet,\nv'hanchileinu Adonai Eloheinu\nb'ahavah uv'ratzon Shabbat kodshecha,\nv'yanuchu vah Yisrael m'kadshei sh'mecha.\nBaruch atah, Adonai, m'kadeish HaShabbat.",
          "language": "en"
        }
      ],
      "created": "2026-07-15T15:04:34.994Z",
      "creator": {
        "isGuest": true,
        "id": "xyRM0JS2uzT6MwCE3pQ2"
