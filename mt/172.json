      "@context": "http://www.w3.org/ns/anno.jsonld",
      "type": "Annotation",
      "body": [
        {
          "type": "TextualBody",
          "purpose": "transcribing",
          "value": "אֱלֹהֵינוּ וֵאלֹהֵי אֲבוֹתֵינוּ וְאִמּוֹתֵינוּ,\nרְצֵה בִמְנוּחָתֵנוּ. קַדְּשֵׁנוּ בְּמִצְוֹתֶיךָ\nוְתֵן חֶלְקֵנוּ בְתוֹרָתֶךָ,\nשַׁבְּעֵנוּ מְטוּבָךְ וְשַׁמְחֲנוּ בִּישׁוּעָתֶךָ,\nוְטַהֵר לִבֵּנוּ לְעָבְדְּךָ בֶּאֱמֶת,\n>>\nוְהַנְחִילֵנוּ, יְיָ אֱלֹהֵינוּ,\nבְּאַהֲבָה וּבְרָצוֹן שַׁבַּת קָדְשֶׁךְ\nוְיָנוּחוּ בָהּ יִשְׂרָאֵל, מְקַדְּשֵׁי שְׁמֶךְ.\nבָּרוּךְ אַתָּה, יְיָ, מְקַדֵּשׁ הַשַׁבָּת.",
          "language": "he"
        }
      ],
      "created": "2026-07-15T15:04:27.082Z",
