    },
    {
      "id": "6ddcf56c-ac7d-4b1e-a4e0-a7548d149614",
      "target": {
        "source": "mishkan:page:189bce48-e52f-44ee-8d1f-2ea21ceaf4a5",
        "type": "SpecificResource",
        "selector": {
          "type": "FragmentSelector",
          "conformsTo": "http://www.w3.org/TR/media-frags/",
          "value": "xywh=pixel:370.2105263157896,5042.631578947367,3653.1578947368416,1053.6842105263158"
        }
      },
      "@context": "http://www.w3.org/ns/anno.jsonld",
      "type": "Annotation",
      "body": [
        {
          "type": "TextualBody",
          "purpose": "transcribing",
          "value": "Our God and God of our ancestors, be pleased with our rest. Sanctify us with Your\nmitzvot, and grant us a share in Your Torah. Satisfy us with Your goodness and gladden\nus with Your salvation. Purify our hearts to serve You in truth. In Your gracious love,\nAdonai our God, grant as our heritage Your Holy Shabbat, that Israel who sanctifies\nYour Name may rest on it. Praise to You, Adonai, who sanctifies Shabbat.\nבָּרוּךְ אַתָּה, יְיָ, מְקַדֵּשׁ הַשַׁבָּת.\nBaruch atah, Adonai, m'kadeish HaShabbat.",
          "language": "en"
        }
      ],
      "created": "2026-07-15T15:04:53.736Z",
      "creator": {
