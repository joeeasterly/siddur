      "@context": "http://www.w3.org/ns/anno.jsonld",
      "type": "Annotation",
      "body": [
        {
          "type": "TextualBody",
          "purpose": "transcribing",
          "value": "וַיְכַלּוּ הַשָּׁמַיִם וְהָאָרֶץ\nוְכָל־צְבָאָם.\nוַיְכַל אֱלֹהִים בַּיּוֹם הַשְּׁבִיעִי\nמְלַאכְתּוֹ אֲשֶׁר עָשָׂה.\nוַיִּשְׁבֹּת בַּיּוֹם הַשְּׁבִיעִי\nמִכָּל־מְלַאכְתּוֹ אֲשֶׁר עָשָׂה.\nוַיְבָרֶךְ אֱלֹהִים אֶת־יוֹם הַשְּׁבִיעִי\nוַיְקַדַּשׁ אֹתוֹ, כִּי בוֹ שָׁבַת מִכָּל־\nמְלַאכְתּוֹ אֲשֶׁר בָּרָא אֱלֹהִים לַעֲשׂוֹת.",
          "language": "he"
        }
      ],
      "created": "2026-07-13T00:53:18.057Z",
