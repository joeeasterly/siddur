      "type": "Annotation",
      "body": [
        {
          "type": "TextualBody",
          "purpose": "transcribing",
          "value": "יִתְגַּדַּל וְיִתְקַדַּשׁ שְׁמֵהּ רַבָּא\nבְּעָלְמָא דִי בְרָא כִרְעוּתֵהּ,\nוְיַמְלִיךְ מַלְכוּתֵהּ\nבְּחַיֵּיכוֹן וּבְיוֹמֵיכוֹן\nוּבְחַיֵּי דְכָל בֵּית יִשְׂרָאֵל,\nבַּעֲגָלָא וּבִזְמַן קָרִיב,\nוְאִמְרוּ: אָמֵן.\nיְהֵא שְׁמֵהּ רַבָּא מְבָרַךְ\nלְעָלַם וּלְעָלְמֵי עָלְמַיָּא.\nיִתְבָּרַךְ וְיִשְׁתַּבַּח וְיִתְפָּאַר\nוְיִתְרוֹמַם וְיִתְנַשֵׂא,\nוְיִתְהַדָּר וְיִתְעַלֶּה וְיִתְהַלֵּל\nשְׁמֵהּ דְּקָדְשָׁא בְּרִיךְ הוּא,\nלְעֵלָא מִן כָּל בִּרְכָתָא וְשִׁירָתָא,\nתִּשְׁבְּחָתָא וְנֶחֱמָתָא,\nדַּאֲמִירָן בְּעָלְמָא, וְאִמְרוּ: אָמֵן.",
          "language": "he"
        }
      ],
