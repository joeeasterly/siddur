    },
    {
      "id": "a6766845-d7c9-463e-9669-8b7eab1fc02a",
      "target": {
        "source": "mishkan:page:f4f3ccdb-8ca7-4e0a-9dd4-d4c2def72c98",
        "type": "SpecificResource",
