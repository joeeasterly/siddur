        <ab xml:id="block_A" xml:lang="he" facs="https://momoiro.hallyu.io/mishkan/iiif/3/mishkan%2F9e003d6e-2f94-40ff-b17f-44c953d93d85.jp2/1637,773,1290,1032/max/0/default.jpg">
          תְּפִלָּה<lb/>
        T FILAH
        </ab>
        <ab xml:id="block_B" xml:lang="he" facs="https://momoiro.hallyu.io/mishkan/iiif/3/mishkan%2F9e003d6e-2f94-40ff-b17f-44c953d93d85.jp2/2808,2282,1379,446/max/0/default.jpg">
          אֲדֹנָי, שְׂפָתַי תִּפְתָּח,<lb/>
        וּפִי יַגִיד תְּהִלָּתֶךָ.
        </ab>
        <ab xml:id="block_C" xml:lang="en" facs="https://momoiro.hallyu.io/mishkan/iiif/3/mishkan%2F9e003d6e-2f94-40ff-b17f-44c953d93d85.jp2/416,2232,2859,1181/max/0/default.jpg">
          ADONAI, s&apos;fatai tiftach,<lb/>
        ufi yagid t&apos;hilatecha.<lb/>
        ADONAI, open up my lips,<lb/>
        that my mouth may declare Your praise.
        </ab>
        <ab xml:id="block_D" xml:lang="en" facs="https://momoiro.hallyu.io/mishkan/iiif/3/mishkan%2F9e003d6e-2f94-40ff-b17f-44c953d93d85.jp2/422,5736,3350,600/max/0/default.jpg">
          For those who choose: Before reciting T&apos;filah, one takes three<lb/>
        steps forward.<lb/>
        Adonai, sfatai tiftach... Adonai, open up my lips... Psalm 51:17
        </ab>
