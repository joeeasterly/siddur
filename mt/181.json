      "body": [
        {
          "type": "TextualBody",
          "purpose": "transcribing",
          "value": "CREATE a pure heart within me;\nlet my soul wake up in Your light.\nOpen me to Your Presence;\nflood me with Your holy spirit.\nThen I will stand and sing out\nthe power of Your forgiveness.\nI will teach Your love to the lonely;\nthe lost will find their way home.\nAdonai, open up my lips\nand my mouth will declare Your praise.",
          "language": "en"
        }
      ],
      "created": "2026-07-17T16:52:36.211Z",
