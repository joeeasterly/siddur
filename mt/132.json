      "body": [
        {
          "type": "TextualBody",
          "purpose": "transcribing",
          "value": "מָלָךְ, תָּגֵל הָאָרֶץ,\nיִשְׂמְחוּ אִים רַבִּים.\nעָנָן וַעֲרָפֶל סְבִיבָיו\nצֶדֶק וּמִשְׁפָּט מְכוֹן כִּסְאוֹ.\nאֹהֲבֵי יְיָ שִׂנְאוּ רָע,\nשֹׁמֵר נַפְשׁוֹת חֲסִידָיו\nמִיַּד רְשָׁעִים יַצִילֵם.\nאוֹר זָרֵעַ לַצַדִּיק\nוּלְיִשְׁרֵי־לֵב שִׂמְחָה.\nשִׂמְחוּ צַדִּיקִים בַּיץ\nוְהוֹדוּ לְזֵכֶר קָדְשׁוֹ.",
          "language": "he"
        }
      ],
