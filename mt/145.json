      "@context": "http://www.w3.org/ns/anno.jsonld",
      "type": "Annotation",
      "body": [
        {
          "type": "TextualBody",
          "purpose": "transcribing",
          "value": "ENTRANCES to holiness are everywhere.\nThe possibility of ascent is all the time,\neven at unlikely times and through unlikely places.\nThere is no place on earth without the Presence.",
          "language": "en"
        }
      ],
