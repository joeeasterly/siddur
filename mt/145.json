      "type": "Annotation",
      "body": [
        {
          "type": "TextualBody",
          "purpose": "transcribing",
          "value": "למדני, אֱלֹהִי, בָּרֵךְ וְהִתְפַּלֵּל\nעל סוֹד עָלֶה קָמֵל,\nעַל נְגַהּ פְּרִי בָּשֵׁל,\nעַל הַחֲרוּת הַזֹּאת:\nלִרְאוֹת, לָחוּשׁ, לִנְשֹׁם,\nלָדַעַת, לְיַחֵל, לְהִכָּשֵׁל.\nלַמֵּד אֶת שִׂפְתוֹתַי\nבְּרָכָה וְשִׁיר הַלֵּל,\nבְּהִתְחַדֵּשׁ זְמַנְךְ\nעם בְּקֶר וְעִם לֵיל,\nלְבַל יִהְיֶה יוֹמִי הַיּוֹם\nכִּתְמוֹל שִׁלְשׁוֹם,\nלְבַל יִהְיֶה עָלַי יּוֹמִי הֶרְגֵל.",
          "language": "he"
        }
      ],
