      "@context": "http://www.w3.org/ns/anno.jsonld",
      "type": "Annotation",
      "body": [
        {
          "type": "TextualBody",
          "purpose": "transcribing",
          "value": "LAMDEINI, Elohai, bareich v’hitpaleil\nal sod aleh kameil,\nal nogah p'ri basheil,\nal hacheirut hazot;\nLirot, lachush, linshom,\nladaat, layacheil, l'hikasheil.\nLameid et siftotai\nb'rachah v'shir hallel,\nb'hit'chadeish z'mancha\nim boker v'im leil,\nI'val yih'yeh yomi hayom\nkitmol shilshom,\nI'val yih'yeh alai yomi hergeil.",
          "language": "en"
        }
      ],
      "created": "2026-07-14T19:48:23.313Z",
      "creator": {
        "isGuest": true,
        "id": "pkthB90MDdhVAuOYaXRX"
      },
      "image_url": "https://momoiro.hallyu.io/mishkan/iiif/3/mishkan%2F6018d4fb-ce9c-48c7-b994-853a4e612645.jp2/812,1080,1625,2303/max/0/default.jpg"
    },
    {
