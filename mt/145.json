          "type": "FragmentSelector",
          "conformsTo": "http://www.w3.org/TR/media-frags/",
          "value": "xywh=pixel:1532.0869565217392,3492.8136645962736,1943.7701863354034,1657.1552795031062"
        }
      },
      "@context": "http://www.w3.org/ns/anno.jsonld",
      "type": "Annotation",
      "body": [
        {
          "type": "TextualBody",
          "purpose": "transcribing",
          "value": "TEACH ME, O God, a blessing, a prayer\non the mystery of a withered leaf,\non ripened fruit so fair,\non the freedom to see, to sense,\nto breathe, to know, to hope, to despair.\nTeach my lips a blessing, a hymn of praise,\nas each morning and night\nYou renew Your days,\nlest my day be today as the one before;\nlest routine set my ways.",
          "language": "en"
        }
      ],
      "created": "2026-07-14T19:48:34.539Z",
