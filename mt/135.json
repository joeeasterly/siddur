      "body": [
        {
          "type": "TextualBody",
          "purpose": "transcribing",
          "value": "מָלָךְ יִרְגְזוּ עַמִּים,\nיֹשֵׁב כְּרוּבִים תָּנוּט הָאָרֶץ.\nיְיָ בְּצִיּוֹן גָּדוֹל\nוְרָם הוּא עַל־כָּל־הָעַמִּים.\nיוֹדוּ שִׁמְךְ גָּדוֹל וְנוֹרָא,\nקָדוֹשׁ הוּא.\nוְעַז מֶלֶךְ מִשְׁפָּט אָהֵב,\nאַתָּה כּוֹנַנְתָּ מֵישָׁרִים,\nמִשְׁפָּט וּצְדָקָה בְּיַעֲקֹב\nאַתָּה עָשִׂיתָ.\nרוֹמְמוּ יְיָ אֱלֹהֵינוּ\nוְהִשְׁתַּחֲווּ לַהֲדֹם רַגְלָיו,\nקָדוֹשׁ הוּא.\nרוֹמְמוּ יְיָ אֱלֹהֵינוּ\nוְהִשְׁתַּחֲווּ לְהַר קָדְשׁוֹ,\nכִּי קָדוֹשׁ יְיָ אֱלֹהֵינוּ.",
          "language": "he"
        }
      ],
