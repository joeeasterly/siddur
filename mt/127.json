      "@context": "http://www.w3.org/ns/anno.jsonld",
      "type": "Annotation",
      "body": [
        {
          "type": "TextualBody",
          "purpose": "transcribing",
          "value": "WE OFFER THANKS, O God, for this Shabbat\nwhich unites us in faith and hope.\nFor Shabbat holiness, which inspires sacred living,\nfor Shabbat memories, glowing even in darkness,\nfor Shabbat peace, born of friendship and love,\nwe offer thanks and blessing, O God.",
          "language": "en"
        }
      ],
